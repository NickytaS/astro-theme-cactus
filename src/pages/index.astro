---
import SocialList from "@/components/SocialList.astro";
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout meta={{ title: "Home" }}>
	<section>
		<h1 class="title mb-12">Nathalie Kahambu Sikihimba</h1>
		<p class="mb-4">
			I am a Computer Science student in Liepaja, Latvia. This website shares my education, experience,
			skills, and portfolio documents.
		</p>
		<SocialList />
	</section>
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">Highlights</h2>
		<p class="mb-4">
			I am currently pursuing a Bachelor degree in Computer Science at RTU Liepaja Academy.
		</p>
		<p class="mb-4">
			I have experience working in a fast-paced team environment through my role at QNQ Restaurant.
		</p>
		<p class="mb-4">
			I communicate confidently in French and English, and Swahili is my native language.
		</p>
		<p>
			My technical skills include JavaScript, TypeScript, HTML, CSS, React Native, Expo, Python,
			and SQL, plus hands-on work with SQLite, MySQL, PostgreSQL, MongoDB, and Docker. I also
			have practical digital skills with Microsoft Office and Microsoft Word.
		</p>
	</section>
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">Projects</h2>
		<ul class="list-inside list-disc space-y-2" role="list">
			<li>
				<a class="cactus-link" href="/projects/smart-appointment/">
					Smart Appointment
				</a>
				- A React Native and Expo mobile app for managing medical appointments with user
				authentication, scheduling, rescheduling/cancellation, doctor profiles, and SQLite
				storage.
			</li>
			<li>
				<a class="cactus-link" href="/projects/database-migration-tool-evaluator/">
					Database Migration Tool Evaluator
				</a>
				- Bachelor project comparing pgLoader, MRM, and Mongify on real MySQL datasets from
				WordPress, WooCommerce, and ERPNext using a weighted evaluation framework.
			</li>
		</ul>
	</section>
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">Curriculum vitae</h2>
		<ul class="list-inside list-disc space-y-2" role="list">
			<li><a class="cactus-link" href="/docs/nathalie-cv.pdf">CV</a></li>
		</ul>
	</section>
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">Certifications</h2>
		<p class="mb-4">
			Verified training certificates highlighting completed courses in web and mobile development.
		</p>
		<ul class="list-inside list-disc space-y-2" role="list">
			<li>
				<a class="cactus-link" href="/certifications/advanced-3d-game-creation/">
					Advanced 3D Game Creation for Browsers
				</a>
				- Tech Optimus, issued October 8, 2024
			</li>
			<li>
				<a class="cactus-link" href="/certifications/react-native-development-social-network/">
					React Native Development for Social Network
				</a>
				- Tech Optimus, issued October 6, 2024
			</li>
			<li>
				<a class="cactus-link" href="/certifications/game-creation-40-hours/">
					3D Game Creation for Browsers (40-hour course)
				</a>
				- Tech Optimus, issued February 25, 2024
			</li>
			<li>
				<a class="cactus-link" href="/certifications/bmw-coding-and-programming/">
					BMW Coding and Programming Course
				</a>
				- BIMDOC, completed May 26, 2024
			</li>
		</ul>
	</section>
</PageLayout>
