---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "3D Game Creation for Browsers (40-hour Course)",
	description:
		"Certificate details for a 40-hour 3D game creation for browsers course with HTML, CSS, and JavaScript.",
};
---

<PageLayout meta={meta}>
	<section>
		<p class="mb-6">
			<a class="cactus-link" href="/">← Back to Home</a>
		</p>
		<h1 class="title mb-8">3D Game Creation for Browsers (40-hour Course)</h1>
		<div class="prose prose-sm prose-cactus max-w-none">
			<p>
				This certificate confirms completion of a 40-hour training focused on creating browser-based
				3D game experiences using web technologies.
			</p>
			<ul>
				<li><strong>Issuer:</strong> Tech Optimus, Lithuanian IT Branch</li>
				<li><strong>Issued to:</strong> Nathalie Sikihimba Kahambu</li>
				<li><strong>Date:</strong> February 25, 2024</li>
				<li><strong>Skills:</strong> HTML, CSS, JavaScript, game-development fundamentals</li>
			</ul>
			<img
				src="/images/scans/document-scan-7-page-1.jpg"
				alt="3D Game Creation for Browsers 40-hour certificate"
				class="mx-auto block h-[70vh] w-auto rounded border object-contain [transform:rotate(-90deg)]"
				loading="lazy"
			/>
		</div>
	</section>
</PageLayout>
