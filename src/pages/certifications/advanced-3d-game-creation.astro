---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "Advanced 3D Game Creation for Browsers",
	description:
		"Certificate details for the Advanced 3D Game Creation for Browsers course using HTML, CSS, and JavaScript.",
};
---

<PageLayout meta={meta}>
	<section>
		<p class="mb-6">
			<a class="cactus-link" href="/">← Back to Home</a>
		</p>
		<h1 class="title mb-8">Advanced 3D Game Creation for Browsers</h1>
		<div class="prose prose-sm prose-cactus max-w-none">
			<p>
				This certificate confirms successful completion of an advanced course focused on building 3D
				browser-based games with core web technologies.
			</p>
			<ul>
				<li><strong>Issuer:</strong> Tech Optimus, Lithuanian IT Branch</li>
				<li><strong>Issued to:</strong> Nathalie Kahambu Sikihimba</li>
				<li><strong>Date:</strong> October 8, 2024</li>
				<li><strong>Skills:</strong> HTML, CSS, JavaScript, 3D game concepts</li>
			</ul>
			<img
				src="/images/scans/document-1-page-1.jpg"
				alt="Advanced 3D Game Creation for Browsers certificate"
				class="mx-auto block h-[70vh] w-auto rounded border object-contain [transform:rotate(-90deg)]"
				loading="lazy"
			/>
		</div>
	</section>
</PageLayout>
