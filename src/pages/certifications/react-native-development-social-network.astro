---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "React Native Development for Social Network",
	description:
		"Certificate details for the React Native Development for Social Network course.",
};
---

<PageLayout meta={meta}>
	<section>
		<p class="mb-6">
			<a class="cactus-link" href="/">← Back to Home</a>
		</p>
		<h1 class="title mb-8">React Native Development for Social Network</h1>
		<div class="prose prose-sm prose-cactus max-w-none">
			<p>
				This certificate recognizes completion of a practical course on building social-network style
				mobile experiences with React Native.
			</p>
			<ul>
				<li><strong>Issuer:</strong> Tech Optimus, Lithuanian IT Branch</li>
				<li><strong>Issued to:</strong> Nathalie Kahambu Sikihimba</li>
				<li><strong>Date:</strong> October 6, 2024</li>
				<li><strong>Skills:</strong> React Native concepts, mobile UI and app development</li>
			</ul>
			<img
				src="/images/scans/document-scan-6-page-1.jpg"
				alt="React Native Development for Social Network certificate"
				class="mx-auto block h-[70vh] w-auto rounded border object-contain [transform:rotate(-90deg)]"
				loading="lazy"
			/>
		</div>
	</section>
</PageLayout>
